<UserControl x:Class="AniTrack.Views.Library.MangaLibraryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:AniTrack.Localization"
             xmlns:vm="clr-namespace:AniTrack.ViewModels.Library"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="1000">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header + search -->
        <Grid Grid.Row="0" Margin="24,18,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{loc:Loc Nav_Manga}"
                       Style="{StaticResource PageTitleText}"/>

            <ui:TextBox Grid.Column="1" Width="240" Margin="0,0,8,0"
                        PlaceholderText="{loc:Loc Library_SearchManga}"
                        Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                        Icon="{ui:SymbolIcon Symbol=Search24}"/>

            <ui:Button Grid.Column="2" Command="{Binding LoadCommand}" Appearance="Secondary"
                       ToolTip="Refresh">
                <ui:SymbolIcon Symbol="ArrowSync24"/>
            </ui:Button>
        </Grid>

        <!-- Status filter tabs (PillTab) -->
        <Border Grid.Row="1" Margin="24,0,24,0"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <RadioButton Style="{StaticResource PillTab}" GroupName="MangaStatus"
                                 Content="{loc:Loc Status_All}"
                                 IsChecked="{Binding ActiveStatusId, ConverterParameter=0, Converter={StaticResource EqualityConverter}}"/>
                    <RadioButton Style="{StaticResource PillTab}" GroupName="MangaStatus"
                                 Content="{loc:Loc Status_Reading}"
                                 IsChecked="{Binding ActiveStatusId, ConverterParameter=2, Converter={StaticResource EqualityConverter}}"/>
                    <RadioButton Style="{StaticResource PillTab}" GroupName="MangaStatus"
                                 Content="{loc:Loc Status_Completed}"
                                 IsChecked="{Binding ActiveStatusId, ConverterParameter=3, Converter={StaticResource EqualityConverter}}"/>
                    <RadioButton Style="{StaticResource PillTab}" GroupName="MangaStatus"
                                 Content="{loc:Loc Status_OnHold}"
                                 IsChecked="{Binding ActiveStatusId, ConverterParameter=4, Converter={StaticResource EqualityConverter}}"/>
                    <RadioButton Style="{StaticResource PillTab}" GroupName="MangaStatus"
                                 Content="{loc:Loc Status_PlanToRead}"
                                 IsChecked="{Binding ActiveStatusId, ConverterParameter=7, Converter={StaticResource EqualityConverter}}"/>
                    <RadioButton Style="{StaticResource PillTab}" GroupName="MangaStatus"
                                 Content="{loc:Loc Status_Favorites}"
                                 IsChecked="{Binding ActiveStatusId, ConverterParameter=99, Converter={StaticResource EqualityConverter}}"/>
                    <RadioButton Style="{StaticResource PillTab}" GroupName="MangaStatus"
                                 Content="{loc:Loc Status_Ratings}"
                                 IsChecked="{Binding ActiveStatusId, ConverterParameter=98, Converter={StaticResource EqualityConverter}}"/>
                </StackPanel>
                <ComboBox Grid.Column="1" Margin="8,4,0,4" MinWidth="200"
                          SelectedIndex="{Binding RatingSortIndex}"
                          Visibility="{Binding IsRatingsTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ComboBoxItem Content="{loc:Loc Ratings_SortHighToLow}"/>
                    <ComboBoxItem Content="{loc:Loc Ratings_SortLowToHigh}"/>
                    <ComboBoxItem Content="{loc:Loc Ratings_SortMalHighToLow}"/>
                    <ComboBoxItem Content="{loc:Loc Ratings_SortAlpha}"/>
                </ComboBox>
            </Grid>
        </Border>

        <!-- Loading bar -->
        <ProgressBar Grid.Row="2" IsIndeterminate="True" Height="2"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <!-- Content -->
        <Grid Grid.Row="3">
            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding Items.Count, ConverterParameter=Invert, Converter={StaticResource CountToVisibilityConverter}}">
                <ui:SymbolIcon Symbol="BookOpen24" FontSize="48"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                <TextBlock Text="{loc:Loc Library_EmptyTitle}" FontSize="16" FontWeight="SemiBold"
                           Margin="0,12,0,4" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="{loc:Loc Library_EmptyMessage}" FontSize="12"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
            </StackPanel>

            <!-- Cards -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding Items.Count, Converter={StaticResource CountToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding Items}" Margin="18,12,18,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:LibraryCardViewModel}">
                            <Border Style="{StaticResource MediaCard}"
                                    Margin="{StaticResource CardMargin}"
                                    Width="150" Height="252"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    MouseLeftButtonUp="Card_MouseLeftButtonUp">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="200"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Cover + badge -->
                                    <Border Grid.Row="0" CornerRadius="{StaticResource CornerCardTop}"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Rectangle Fill="{DynamicResource ControlFillColorDefaultBrush}"/>
                                            <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                            <Border VerticalAlignment="Top" HorizontalAlignment="Left"
                                                    Margin="8" Padding="7,3"
                                                    CornerRadius="{StaticResource CornerPill}"
                                                    Background="{Binding StatusBackground}">
                                                <TextBlock Text="{Binding StatusName}"
                                                           FontSize="9" FontWeight="SemiBold"
                                                           Foreground="{Binding StatusForeground}"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Grid.Row="1" Margin="10,7,10,8">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Height="30" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding ProgressText}"
                                                   FontSize="10" Margin="0,2,0,4"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <ProgressBar Style="{StaticResource BrandProgressBar}"
                                                     Minimum="0" Maximum="100"
                                                     Value="{Binding ProgressPercent, Mode=OneWay}"
                                                     Foreground="{Binding ProgressAccent}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
