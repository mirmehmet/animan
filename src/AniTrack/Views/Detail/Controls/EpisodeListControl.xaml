<UserControl x:Class="AniTrack.Views.Detail.Controls.EpisodeListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <VirtualizingStackPanel>
        <ItemsControl ItemsSource="{Binding Episodes}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12,6"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0" Margin="0,0,12,0"
                                      IsChecked="{Binding IsWatched}"
                                      Command="{Binding ToggleWatchedCommand}"/>

                            <TextBlock Grid.Column="1" Margin="0,0,12,0"
                                       Text="{Binding EpisodeNumber, StringFormat='Ep {0}'}"
                                       FontWeight="SemiBold" VerticalAlignment="Center"
                                       MinWidth="50"/>

                            <TextBlock Grid.Column="2" Text="{Binding Title}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                            <ui:Button Grid.Column="3" Margin="8,0"
                                        Command="{Binding OpenNoteCommand}"
                                        Appearance="Transparent"
                                        ToolTip="Note">
                                <ui:SymbolIcon Symbol="Note24"/>
                            </ui:Button>

                            <ui:Button Grid.Column="4"
                                        Command="{Binding MarkUpToHereCommand}"
                                        Appearance="Transparent"
                                        ToolTip="Mark up to here">
                                <ui:SymbolIcon Symbol="CheckmarkCircle24"/>
                            </ui:Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </VirtualizingStackPanel>
</UserControl>
