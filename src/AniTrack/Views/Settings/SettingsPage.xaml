<UserControl x:Class="AniTrack.Views.Settings.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:AniTrack.Localization"
             xmlns:domain="clr-namespace:AniTrack.Core.Domain.Models;assembly=AniTrack.Core"
             d:DesignHeight="700" d:DesignWidth="800"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <StackPanel.Resources>
                <Style TargetType="ui:CardControl">
                    <Setter Property="Margin" Value="0,0,0,8"/>
                </Style>
                <Style TargetType="TextBlock" x:Key="SectionHeader">
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Margin" Value="0,16,0,8"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                </Style>
            </StackPanel.Resources>

            <TextBlock Text="{loc:Loc Settings_Title}" FontSize="24" FontWeight="SemiBold"
                       Margin="0,0,0,16"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

            <!-- ── Appearance ──────────────────────────────────────────────── -->

            <ui:CardControl Icon="{ui:SymbolIcon Symbol=DarkTheme24}"
                            Header="{loc:Loc Settings_DarkMode}">
                <ui:ToggleSwitch IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
                                 Command="{Binding ToggleThemeCommand}"/>
            </ui:CardControl>

            <ui:CardControl Icon="{ui:SymbolIcon Symbol=LocalLanguage24}"
                            Header="{loc:Loc Settings_Language}">
                <ComboBox ItemsSource="{Binding Languages}"
                          SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                          DisplayMemberPath="Display"
                          MinWidth="140"/>
            </ui:CardControl>

            <ui:CardControl Icon="{ui:SymbolIcon Symbol=Home24}"
                            Header="{loc:Loc Settings_StartupPage}">
                <ComboBox ItemsSource="{Binding StartupPageOptions}"
                          SelectedItem="{Binding SelectedStartupPage, Mode=TwoWay}"
                          MinWidth="140"/>
            </ui:CardControl>

            <!-- ── Data / Backup ───────────────────────────────────────────── -->

            <TextBlock Text="{loc:Loc Settings_Export}" Style="{StaticResource SectionHeader}"/>

            <ui:CardControl Icon="{ui:SymbolIcon Symbol=ArrowExportUp24}"
                            Header="{loc:Loc Settings_Export}">
                <ui:Button Content="{loc:Loc Settings_Export}"
                           Command="{Binding ExportDataCommand}"
                           Appearance="Secondary"/>
            </ui:CardControl>

            <ui:CardControl Icon="{ui:SymbolIcon Symbol=ArrowImport24}"
                            Header="{loc:Loc Settings_Import}">
                <ui:Button Content="{loc:Loc Settings_Import}"
                           Command="{Binding ImportDataCommand}"
                           Appearance="Secondary"/>
            </ui:CardControl>

            <!-- ── Trash ───────────────────────────────────────────────────── -->

            <TextBlock Text="{loc:Loc Settings_Trash}" Style="{StaticResource SectionHeader}"/>

            <StackPanel Margin="0,0,0,8">
                <!-- Trash list header row -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:Button Grid.Column="1"
                               Content="{loc:Loc Settings_EmptyTrash}"
                               Command="{Binding EmptyTrashCommand}"
                               Appearance="Caution"
                               HorizontalAlignment="Right"/>
                </Grid>

                <!-- Loading indicator for trash -->
                <ProgressBar IsIndeterminate="True" Height="2" Margin="0,0,0,8"
                             Visibility="{Binding IsTrashLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- Empty trash state -->
                <TextBlock Text="{loc:Loc Settings_TrashEmpty}"
                           FontSize="12" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Margin="0,8,0,8"
                           Visibility="{Binding TrashItems.Count, ConverterParameter=Invert,
                               Converter={StaticResource CountToVisibilityConverter}}"/>

                <!-- Trash items list -->
                <ItemsControl ItemsSource="{Binding TrashItems}"
                              Visibility="{Binding TrashItems.Count, Converter={StaticResource CountToVisibilityConverter}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type domain:LibraryItem}">
                            <ui:CardControl Margin="0,0,0,4">
                                <ui:CardControl.Icon>
                                    <ui:SymbolIcon Symbol="Delete24"/>
                                </ui:CardControl.Icon>
                                <ui:CardControl.Header>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Snapshot.Title}"
                                                   FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Text="{Binding DeletedAt,
                                                       Converter={StaticResource DaysRemainingConverter},
                                                       StringFormat='{}{0} days left'}"/>
                                    </StackPanel>
                                </ui:CardControl.Header>
                                <ui:Button Content="{loc:Loc Common_Restore}"
                                           Appearance="Secondary"
                                           Command="{Binding DataContext.RestoreItemCommand,
                                               RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                           CommandParameter="{Binding}"/>
                            </ui:CardControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- ── About ───────────────────────────────────────────────────── -->

            <TextBlock Text="{loc:Loc Settings_About}" Style="{StaticResource SectionHeader}"/>

            <ui:CardControl Icon="{ui:SymbolIcon Symbol=Info24}"
                            Header="AniTrack">
                <TextBlock Text="{loc:Loc Settings_AppVersion}"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </ui:CardControl>

            <ui:CardControl Icon="{ui:SymbolIcon Symbol=Globe24}"
                            Header="{loc:Loc Settings_DataSource}">
                <TextBlock Text="Jikan API (api.jikan.moe)"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </ui:CardControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
