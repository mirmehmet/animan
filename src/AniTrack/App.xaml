<Application x:Class="AniTrack.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:AniTrack.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Wpf.Ui must come first so our overrides below take precedence -->
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
                <!-- Design system: tokens → palette → styles (order matters) -->
                <ResourceDictionary Source="Themes/Tokens.xaml"/>
                <ResourceDictionary Source="Themes/Palette.xaml"/>
                <ResourceDictionary Source="Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <conv:CountToVisibilityConverter       x:Key="CountToVisibilityConverter"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
            <conv:EqualityConverter                x:Key="EqualityConverter"/>
            <conv:DaysRemainingConverter           x:Key="DaysRemainingConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
