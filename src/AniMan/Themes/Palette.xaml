<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brand Violet -->
    <SolidColorBrush x:Key="BrandAccentBrush"     Color="#8B5CF6"/>
    <SolidColorBrush x:Key="BrandAccentLightBrush" Color="#A78BFA"/>
    <SolidColorBrush x:Key="BrandAccentDimBrush"   Color="#6D28D9"/>

    <!-- Violet → Pink gradient for hero / featured accents -->
    <LinearGradientBrush x:Key="BrandGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#8B5CF6" Offset="0"/>
        <GradientStop Color="#EC4899" Offset="1"/>
    </LinearGradientBrush>

    <!-- Hero banner background -->
    <LinearGradientBrush x:Key="HeroBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1a0d33" Offset="0"/>
        <GradientStop Color="#2d1b4e" Offset="1"/>
    </LinearGradientBrush>

    <!-- Overlays -->
    <SolidColorBrush x:Key="CardOverlayBrush"    Color="#CC000000"/>
    <SolidColorBrush x:Key="HairlineBorderBrush"  Color="#14FFFFFF"/>

    <!-- Status palette (mirrors LibraryCardViewModel defaults) -->
    <SolidColorBrush x:Key="Status.WatchingBg"  Color="#2E1F47"/>
    <SolidColorBrush x:Key="Status.WatchingFg"  Color="#B79CF0"/>
    <SolidColorBrush x:Key="Status.CompletedBg" Color="#13301F"/>
    <SolidColorBrush x:Key="Status.CompletedFg" Color="#4FB07A"/>
    <SolidColorBrush x:Key="Status.OnHoldBg"    Color="#332814"/>
    <SolidColorBrush x:Key="Status.OnHoldFg"    Color="#C9A23E"/>
    <SolidColorBrush x:Key="Status.DroppedBg"   Color="#341515"/>
    <SolidColorBrush x:Key="Status.DroppedFg"   Color="#D06A6A"/>
    <SolidColorBrush x:Key="Status.PlannedBg"   Color="#202329"/>
    <SolidColorBrush x:Key="Status.PlannedFg"   Color="#9CA0A8"/>

</ResourceDictionary>
