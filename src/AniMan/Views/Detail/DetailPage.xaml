<UserControl x:Class="AniMan.Views.Detail.DetailPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:AniMan.Views.Detail.Controls"
             xmlns:ctrl="clr-namespace:AniMan.Controls"
             xmlns:loc="clr-namespace:AniMan.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,44,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: Cover + Metadata -->
            <Grid Grid.Row="0" Margin="24,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Cover -->
                <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True"
                        Width="180" Height="260">
                    <Grid>
                        <Rectangle Fill="{DynamicResource ControlFillColorDefaultBrush}"/>
                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                    </Grid>
                </Border>

                <!-- Metadata -->
                <StackPanel Grid.Column="1" Margin="24,0,0,0">
                    <TextBlock Text="{Binding MediaSnapshot.Title}"
                               FontSize="24" FontWeight="Bold"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding MediaSnapshot.TitleJapanese}"
                               FontSize="13" Margin="0,4,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                    <!-- Metadata InfoRows (visible in both modes; each auto-hides when empty) -->
                    <StackPanel Margin="0,12,0,0">
                        <ctrl:InfoRow Label="{loc:Loc Detail_Type}"     Value="{Binding MediaSnapshot.Type}"/>
                        <ctrl:InfoRow Label="{loc:Loc Detail_Episodes}" Value="{Binding MediaSnapshot.TotalEpisodes, TargetNullValue='', StringFormat={}{0}}"/>
                        <ctrl:InfoRow Label="{loc:Loc Detail_Chapters}" Value="{Binding MediaSnapshot.TotalChapters, TargetNullValue='', StringFormat={}{0}}"/>
                        <ctrl:InfoRow Label="{loc:Loc Detail_Volumes}"  Value="{Binding MediaSnapshot.TotalVolumes, TargetNullValue='', StringFormat={}{0}}"/>
                        <ctrl:InfoRow Label="{loc:Loc Detail_Season}"   Value="{Binding SeasonDisplay}"/>
                        <ctrl:InfoRow Label="{loc:Loc Detail_Aired}"    Value="{Binding AiringDisplay}"/>
                        <ctrl:InfoRow Label="{Binding StudioLabel}"     Value="{Binding MediaSnapshot.Studio}"/>
                        <ctrl:InfoRow Label="{loc:Loc Detail_Status}"   Value="{Binding StatusDisplay}"/>
                    </StackPanel>

                    <!-- Genre pills -->
                    <ItemsControl ItemsSource="{Binding Genres}" Margin="0,8,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource GenrePill}">
                                    <TextBlock Text="{Binding}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrandAccentBrush}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Streaming platforms (anime only) -->
                    <StackPanel Margin="0,12,0,0"
                                Visibility="{Binding IsManga, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <TextBlock Text="{loc:Loc Detail_Streaming}"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"
                                   Visibility="{Binding HasStreamingPlatforms, Converter={StaticResource BoolToVisibility}}"/>
                        <ItemsControl ItemsSource="{Binding StreamingPlatforms}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Background="{Binding Background}" Foreground="White"
                                            Tag="{Binding Url}" Margin="0,0,6,4" Padding="10,5"
                                            Cursor="Hand" Click="OnStreamingPlatformClicked"
                                            BorderThickness="0">
                                        <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- MAL link -->
                    <ui:Button Margin="0,6,0,14" Content="{loc:Loc Detail_OpenOnMal}"
                               Command="{Binding OpenOnMalCommand}" Appearance="Secondary"
                               HorizontalAlignment="Left"/>

                    <!-- Library actions (hidden in preview mode) -->
                    <StackPanel Margin="0,14,0,0"
                                Visibility="{Binding IsPreviewMode,
                                    Converter={StaticResource InverseBoolToVisibilityConverter}}">

                        <!-- Action buttons row: Heart + Refresh + Delete -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <ui:Button Command="{Binding ToggleFavoriteCommand}"
                                       Appearance="Transparent" Margin="0,0,8,0"
                                       ToolTip="Favorite">
                                <ui:SymbolIcon Symbol="Heart24">
                                    <ui:SymbolIcon.Style>
                                        <Style TargetType="ui:SymbolIcon">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                    <Setter Property="Foreground" Value="#FF69B4"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:SymbolIcon.Style>
                                </ui:SymbolIcon>
                            </ui:Button>
                            <ui:Button Command="{Binding ReSnapshotCommand}"
                                       Appearance="Secondary" Margin="0,0,8,0"
                                       Content="{loc:Loc Detail_RefreshData}"/>
                            <ui:Button Command="{Binding SoftDeleteCommand}"
                                       Appearance="Transparent" Margin="0,0,0,0"
                                       ToolTip="{loc:Loc Detail_Delete}"
                                       Click="OnDeleteClicked">
                                <ui:SymbolIcon Symbol="Delete24"/>
                            </ui:Button>
                        </StackPanel>

                        <!-- Status pills (Anime) -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10"
                                    Visibility="{Binding IsManga, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <RadioButton Style="{StaticResource StatusPillRadio}" GroupName="AnimeStatus"
                                         Content="{loc:Loc Status_Watching}" Tag="1" Click="OnStatusPillClicked"
                                         IsChecked="{Binding CurrentStatusId, Converter={StaticResource EqualityConverter}, ConverterParameter=1, Mode=OneWay}"/>
                            <RadioButton Style="{StaticResource StatusPillRadio}" GroupName="AnimeStatus"
                                         Content="{loc:Loc Status_PlanToWatch}" Tag="6" Click="OnStatusPillClicked"
                                         IsChecked="{Binding CurrentStatusId, Converter={StaticResource EqualityConverter}, ConverterParameter=6, Mode=OneWay}"/>
                            <RadioButton Style="{StaticResource StatusPillRadio}" GroupName="AnimeStatus"
                                         Content="{loc:Loc Status_Completed}" Tag="3" Click="OnStatusPillClicked"
                                         IsChecked="{Binding CurrentStatusId, Converter={StaticResource EqualityConverter}, ConverterParameter=3, Mode=OneWay}"/>
                            <RadioButton Style="{StaticResource StatusPillRadio}" GroupName="AnimeStatus"
                                         Content="{loc:Loc Status_OnHold}" Tag="4" Click="OnStatusPillClicked"
                                         IsChecked="{Binding CurrentStatusId, Converter={StaticResource EqualityConverter}, ConverterParameter=4, Mode=OneWay}"/>
                            <RadioButton Style="{StaticResource StatusPillRadio}" GroupName="AnimeStatus"
                                         Content="{loc:Loc Status_Dropped}" Tag="5" Click="OnStatusPillClicked"
                                         IsChecked="{Binding CurrentStatusId, Converter={StaticResource EqualityConverter}, ConverterParameter=5, Mode=OneWay}"/>
                        </StackPanel>

                        <!-- Status pills (Manga) -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10"
                                    Visibility="{Binding IsManga, Converter={StaticResource BoolToVisibility}}">
                            <RadioButton Style="{StaticResource StatusPillRadio}" GroupName="MangaStatus"
                                         Content="{loc:Loc Status_Reading}" Tag="2" Click="OnStatusPillClicked"
                                         IsChecked="{Binding CurrentStatusId, Converter={StaticResource EqualityConverter}, ConverterParameter=2, Mode=OneWay}"/>
                            <RadioButton Style="{StaticResource StatusPillRadio}" GroupName="MangaStatus"
                                         Content="{loc:Loc Status_PlanToRead}" Tag="7" Click="OnStatusPillClicked"
                                         IsChecked="{Binding CurrentStatusId, Converter={StaticResource EqualityConverter}, ConverterParameter=7, Mode=OneWay}"/>
                            <RadioButton Style="{StaticResource StatusPillRadio}" GroupName="MangaStatus"
                                         Content="{loc:Loc Status_Completed}" Tag="3" Click="OnStatusPillClicked"
                                         IsChecked="{Binding CurrentStatusId, Converter={StaticResource EqualityConverter}, ConverterParameter=3, Mode=OneWay}"/>
                            <RadioButton Style="{StaticResource StatusPillRadio}" GroupName="MangaStatus"
                                         Content="{loc:Loc Status_OnHold}" Tag="4" Click="OnStatusPillClicked"
                                         IsChecked="{Binding CurrentStatusId, Converter={StaticResource EqualityConverter}, ConverterParameter=4, Mode=OneWay}"/>
                            <RadioButton Style="{StaticResource StatusPillRadio}" GroupName="MangaStatus"
                                         Content="{loc:Loc Status_Dropped}" Tag="5" Click="OnStatusPillClicked"
                                         IsChecked="{Binding CurrentStatusId, Converter={StaticResource EqualityConverter}, ConverterParameter=5, Mode=OneWay}"/>
                        </StackPanel>

                        <!-- MAL score + User rating row -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{loc:Loc Detail_MalScore}"
                                       FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding MediaSnapshot.MalScore, StringFormat=' {0:0.00}'}"
                                       FontSize="12" VerticalAlignment="Center" Margin="0,0,24,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{loc:Loc Detail_MyRating}"
                                       FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBox x:Name="RatingTextBox"
                                     Width="60" Margin="6,0,4,0"
                                     FontSize="12" VerticalAlignment="Center"
                                     HorizontalContentAlignment="Center"
                                     Text="{Binding UserRating, TargetNullValue='', StringFormat={}{0:0.0}}"
                                     KeyDown="OnRatingKeyDown"
                                     LostFocus="OnRatingLostFocus"/>
                            <TextBlock Text="/ 10" FontSize="12" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>

                    </StackPanel>

                    <!-- Add to Library button (preview mode only) -->
                    <ui:Button Margin="0,16,0,0"
                               Content="{loc:Loc Discover_AddToLibrary}"
                               Appearance="Primary"
                               Click="OnAddToLibraryClicked"
                               Visibility="{Binding IsPreviewMode,
                                   Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Progress bar (library mode, has episodes or chapters) -->
                    <StackPanel Margin="0,12,0,0"
                                Visibility="{Binding HasProgress, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Margin="0,0,0,4">
                            <Run Text="{Binding WatchedCount, Mode=OneWay}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                            <Run Text="{Binding ProgressSuffix, Mode=OneWay}"/>
                        </TextBlock>
                        <ProgressBar Style="{StaticResource BrandProgressBar}"
                                     Value="{Binding WatchedCount, Mode=OneWay}"
                                     Maximum="{Binding TotalCount}"/>
                    </StackPanel>

                    <!-- Synopsis -->
                    <TextBlock Text="{Binding MediaSnapshot.Synopsis}"
                               Margin="0,16,0,0" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Grid>

            <!-- Series Note (hidden in preview) -->
            <StackPanel Grid.Row="1" Margin="24,0,0,16"
                        Visibility="{Binding IsPreviewMode,
                            Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <TextBlock Text="{loc:Loc Detail_SeriesNotes}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ui:TextBox Text="{Binding SeriesNote, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" MinHeight="80"
                             PlaceholderText="{loc:Loc Detail_NotesPlaceholder}"/>
                <ui:Button Margin="0,6,0,0" Content="{loc:Loc Detail_SaveNote}"
                            Command="{Binding SaveSeriesNoteCommand}"
                            Appearance="Secondary" HorizontalAlignment="Right"/>
            </StackPanel>

            <!-- Episode list (anime, library mode) -->
            <StackPanel Grid.Row="2" Margin="24,0,0,0"
                        Visibility="{Binding HasEpisodes, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{loc:Loc Detail_Episodes}" FontWeight="SemiBold" FontSize="16"
                           Margin="0,0,0,8"/>
                <controls:EpisodeListControl DataContext="{Binding}"/>
            </StackPanel>

            <!-- Chapter list (manga, library mode) -->
            <StackPanel Grid.Row="3" Margin="24,0,0,0"
                        Visibility="{Binding HasChapters, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{loc:Loc Detail_Chapters}" FontWeight="SemiBold" FontSize="16"
                           Margin="0,0,0,8"/>
                <controls:ChapterListControl DataContext="{Binding}"/>
            </StackPanel>

        </Grid>
    </ScrollViewer>

    <!-- Floating back button — stays visible while the content scrolls under it -->
    <Border HorizontalAlignment="Left" VerticalAlignment="Top"
            Margin="16,12,0,0" CornerRadius="6"
            Background="{DynamicResource ControlFillColorDefaultBrush}">
        <Button Click="OnGoBackClicked"
                Content="{Binding BackLabel}"
                Background="Transparent" BorderThickness="0"
                Cursor="Hand" Padding="8,4"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
    </Border>
    </Grid>
</UserControl>
