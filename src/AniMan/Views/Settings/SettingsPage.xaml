<UserControl x:Class="AniMan.Views.Settings.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:AniMan.Localization"
             xmlns:vm="clr-namespace:AniMan.ViewModels.Settings"
             xmlns:domain="clr-namespace:AniMan.Core.Domain.Models;assembly=AniMan.Core"
             d:DesignHeight="700" d:DesignWidth="800"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="760" HorizontalAlignment="Left">

            <TextBlock Text="{loc:Loc Settings_Title}"
                       Style="{StaticResource PageTitleText}"
                       Margin="0,0,0,8"/>

            <!-- ══ Appearance ════════════════════════════════════════════════ -->
            <TextBlock Text="{loc:Loc Settings_Appearance}" Style="{StaticResource SectionSubheaderText}"/>

            <!-- Theme: segmented Light / Dark / System -->
            <ui:CardControl Style="{StaticResource SettingCard}"
                            Icon="{ui:SymbolIcon Symbol=DarkTheme24}"
                            Header="{loc:Loc Settings_Theme}">
                <Border CornerRadius="6" ClipToBounds="True"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Style="{StaticResource SegmentRadioButton}" GroupName="ThemeMode"
                                     Content="{loc:Loc Settings_ThemeLight}"
                                     IsChecked="{Binding SelectedThemeMode,
                                         Converter={StaticResource EqualityConverter},
                                         ConverterParameter={x:Static vm:ThemeMode.Light}, Mode=OneWay}"
                                     Command="{Binding SetThemeModeCommand}"
                                     CommandParameter="{x:Static vm:ThemeMode.Light}"/>
                        <RadioButton Style="{StaticResource SegmentRadioButton}" GroupName="ThemeMode"
                                     Content="{loc:Loc Settings_ThemeDark}"
                                     IsChecked="{Binding SelectedThemeMode,
                                         Converter={StaticResource EqualityConverter},
                                         ConverterParameter={x:Static vm:ThemeMode.Dark}, Mode=OneWay}"
                                     Command="{Binding SetThemeModeCommand}"
                                     CommandParameter="{x:Static vm:ThemeMode.Dark}"/>
                        <RadioButton Style="{StaticResource SegmentRadioButton}" GroupName="ThemeMode"
                                     Content="{loc:Loc Settings_ThemeSystem}"
                                     IsChecked="{Binding SelectedThemeMode,
                                         Converter={StaticResource EqualityConverter},
                                         ConverterParameter={x:Static vm:ThemeMode.System}, Mode=OneWay}"
                                     Command="{Binding SetThemeModeCommand}"
                                     CommandParameter="{x:Static vm:ThemeMode.System}"/>
                    </StackPanel>
                </Border>
            </ui:CardControl>

            <ui:CardControl Style="{StaticResource SettingCard}"
                            Icon="{ui:SymbolIcon Symbol=LocalLanguage24}"
                            Header="{loc:Loc Settings_Language}">
                <ComboBox ItemsSource="{Binding Languages}"
                          SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                          DisplayMemberPath="Display"
                          MinWidth="160"/>
            </ui:CardControl>

            <!-- Font selector -->
            <ui:CardControl Style="{StaticResource SettingCard}"
                            Icon="{ui:SymbolIcon Symbol=TextFont24}"
                            Header="{loc:Loc Settings_Font}">
                <ComboBox ItemsSource="{Binding FontOptions}"
                          SelectedItem="{Binding SelectedFont, Mode=TwoWay}"
                          MinWidth="160"/>
            </ui:CardControl>

            <ui:CardControl Style="{StaticResource SettingCard}"
                            Icon="{ui:SymbolIcon Symbol=Home24}"
                            Header="{loc:Loc Settings_StartupPage}">
                <ComboBox ItemsSource="{Binding StartupPageOptions}"
                          SelectedItem="{Binding SelectedStartupPage, Mode=TwoWay}"
                          MinWidth="160"/>
            </ui:CardControl>

            <!-- ══ Data & Backup ═════════════════════════════════════════════ -->
            <TextBlock Text="{loc:Loc Settings_DataBackup}" Style="{StaticResource SectionSubheaderText}"/>

            <ui:CardControl Style="{StaticResource SettingCard}"
                            Icon="{ui:SymbolIcon Symbol=ArrowExportUp24}"
                            Header="{loc:Loc Settings_Export}">
                <ui:Button Content="{loc:Loc Settings_ExportAction}"
                           Command="{Binding ExportDataCommand}"
                           Appearance="Secondary"/>
            </ui:CardControl>

            <ui:CardControl Style="{StaticResource SettingCard}"
                            Icon="{ui:SymbolIcon Symbol=ArrowImport24}"
                            Header="{loc:Loc Settings_Import}">
                <ui:Button Content="{loc:Loc Settings_ImportAction}"
                           Command="{Binding ImportDataCommand}"
                           Appearance="Secondary"/>
            </ui:CardControl>

            <!-- ══ Trash ═════════════════════════════════════════════════════ -->
            <Grid Margin="2,18,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{loc:Loc Settings_Trash}"
                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <ui:Button Grid.Column="1" Content="{loc:Loc Settings_EmptyTrash}"
                           Appearance="Caution" Click="OnEmptyTrashClicked"
                           Visibility="{Binding HasTrashItems, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>

            <ProgressBar IsIndeterminate="True" Height="2" Margin="0,0,0,8"
                         Visibility="{Binding IsTrashLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- Empty state -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="{StaticResource CornerSm}" Padding="0,20" Margin="0,0,0,8"
                    Visibility="{Binding HasTrashItems, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="Delete24" FontSize="28"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                    <TextBlock Text="{loc:Loc Settings_TrashEmpty}"
                               FontSize="12" Margin="0,6,0,0" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Trash items -->
            <ItemsControl ItemsSource="{Binding TrashItems}"
                          Visibility="{Binding HasTrashItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type domain:LibraryItem}">
                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Icon>
                                <ui:SymbolIcon Symbol="Delete24"/>
                            </ui:CardControl.Icon>
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="{Binding Snapshot.Title}"
                                               FontWeight="SemiBold" FontSize="13"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Text="{Binding DeletedAt,
                                                   Converter={StaticResource DaysRemainingConverter},
                                                   StringFormat='{}{0} days left'}"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ui:Button Content="{loc:Loc Common_Restore}"
                                       Appearance="Secondary"
                                       Command="{Binding DataContext.RestoreItemCommand,
                                           RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                       CommandParameter="{Binding}"/>
                        </ui:CardControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ══ About ═════════════════════════════════════════════════════ -->
            <TextBlock Text="{loc:Loc Settings_About}" Style="{StaticResource SectionSubheaderText}"/>

            <ui:CardControl Style="{StaticResource SettingCard}"
                            Icon="{ui:SymbolIcon Symbol=Info24}"
                            Header="AniMan">
                <TextBlock Text="{loc:Loc Settings_AppVersion}"
                           FontSize="12" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </ui:CardControl>

            <ui:CardControl Style="{StaticResource SettingCard}"
                            Icon="{ui:SymbolIcon Symbol=Globe24}"
                            Header="{loc:Loc Settings_DataSource}">
                <TextBlock Text="Jikan API (api.jikan.moe)"
                           FontSize="12" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </ui:CardControl>

            <ui:CardControl Style="{StaticResource SettingCard}"
                            Icon="{ui:SymbolIcon Symbol=Code24}"
                            Header="{loc:Loc Settings_GitHub}">
                <ui:HyperlinkButton Content="github.com/mirmehmet/animan"
                                    NavigateUri="https://github.com/mirmehmet/animan"/>
            </ui:CardControl>

            <!-- ══ Danger Zone ═══════════════════════════════════════════════ -->
            <Separator Margin="0,16,0,16"/>

            <Grid Margin="2,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Grid.Column="0" Symbol="Warning24" FontSize="16"
                               Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1"
                           Text="{loc:Loc Settings_DangerZone}"
                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>
            </Grid>

            <TextBlock Text="{loc:Loc Settings_DeleteAllDataDesc}"
                       TextWrapping="Wrap" FontSize="12" Margin="2,0,0,8"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>

            <ui:CardControl Style="{StaticResource SettingCard}"
                            Icon="{ui:SymbolIcon Symbol=Delete24}"
                            Header="{loc:Loc Settings_DeleteAllData}">
                <ui:Button Content="{loc:Loc Settings_DeleteAllData}"
                           Appearance="Danger"
                           Click="OnDeleteAllDataClicked"/>
            </ui:CardControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
