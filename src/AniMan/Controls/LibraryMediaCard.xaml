<UserControl x:Class="AniMan.Controls.LibraryMediaCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:AniMan.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="262" d:DesignWidth="150"
             x:Name="Root">

    <Border Style="{StaticResource MediaCard}"
            Width="150" Height="262"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            AutomationProperties.Name="{Binding Title, ElementName=Root}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="200"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Cover area + status badge -->
            <Border Grid.Row="0"
                    CornerRadius="{StaticResource CornerCardTop}"
                    ClipToBounds="True">
                <Grid>
                    <!-- Placeholder fill shown while cover is loading or missing -->
                    <Rectangle Fill="{DynamicResource ControlFillColorDefaultBrush}"/>

                    <Image Source="{Binding CoverSource, ElementName=Root}"
                           Stretch="UniformToFill"/>

                    <!-- Status badge -->
                    <Border VerticalAlignment="Top" HorizontalAlignment="Left"
                            Margin="8" Padding="7,3"
                            CornerRadius="{StaticResource CornerSm}"
                            Background="{Binding StatusBackground, ElementName=Root}">
                        <TextBlock Text="{Binding StatusName, ElementName=Root}"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{Binding StatusForeground, ElementName=Root}"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Title + progress -->
            <StackPanel Grid.Row="1" Margin="10,6,10,6">
                <TextBlock Text="{Binding Title, ElementName=Root}"
                           FontSize="11" FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                <!-- Progress (default footer) -->
                <StackPanel Visibility="{Binding ShowRatings, ElementName=Root,
                                Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding ProgressText, ElementName=Root}"
                               FontSize="10" Margin="0,4,0,4"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                    <ProgressBar Minimum="0" Maximum="100"
                                 Value="{Binding ProgressPercent, ElementName=Root, Mode=OneWay}"
                                 Height="4" BorderThickness="0"
                                 Foreground="{Binding ProgressAccent, ElementName=Root}"/>
                </StackPanel>

                <!-- Ratings (My Ratings tab footer): MAL score | user rating -->
                <Grid Margin="0,5,0,0"
                      Visibility="{Binding ShowRatings, ElementName=Root,
                          Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center"
                                ToolTip="{loc:Loc Detail_MalScore}">
                        <TextBlock Text="★" FontSize="11"
                                   Foreground="{StaticResource BrandAccentLightBrush}"/>
                        <TextBlock Text="{Binding MalScoreText, ElementName=Root}"
                                   FontSize="11" Margin="4,0,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <Border Grid.Column="1" Padding="7,2"
                            CornerRadius="{StaticResource CornerTag}"
                            Background="{StaticResource GenreTagBackgroundBrush}"
                            ToolTip="{loc:Loc Detail_MyRating}">
                        <TextBlock Text="{Binding UserRatingText, ElementName=Root}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandAccentBrush}"/>
                    </Border>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
